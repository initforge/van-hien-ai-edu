# Van-Hiên — Environment Variables Reference
# Copy to .dev.vars (wrangler dev)
# NEVER commit .env / .dev.vars to git

# ── Backend ─────────────────────────────────────────────────────────────────
# Set via: npx wrangler secret put JWT_SECRET
JWT_SECRET=your-secret-here

# ── Cloudflare Bindings (info only — IDs set in wrangler.toml) ─────────────────
# KV Namespace ID: 608c82fc3a3945e3b52d5e08372a6abe
# D1 Database ID:  de087f62-62c6-4896-8646-f70aa9fcbc72
#
# To create prod namespaces:
#   npx wrangler kv:namespace create VANHIEN_KV --env production
#   npx wrangler d1 create vanhien-db --env production
# Then update wrangler.prod.toml with the new IDs.
